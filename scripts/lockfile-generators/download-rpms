#!/bin/bash

# --- Configuration & Defaults ---
DEST_DIR="./cachi2/output/deps/rpm"
LOCKFILE=""

# --- Functions ---

usage() {
    echo "Usage: $0 --lock-file <path>"
    echo ""
    echo "Options:"
    echo "  -l, --lock-file    Path to the lock.yaml file (e.g., codeserver/ubi9-python-3.12/prefetch-input/rpms.lock.yaml)"
    echo "  -h, --help         Display this help message"
    echo ""
    echo "Note: This script must be run from the project root directory."
    exit 1
}

# --- Root Directory Validation ---
# We check for a known unique path to ensure we are in the project root.
if [ ! -f "scripts/lockfile-generators/download-rpms" ]; then
    echo "Error: This script must be executed from the project root directory."
    echo "Current directory: $(pwd)"
    exit 1
fi

# --- Argument Parsing ---
# Support both -l and --lock-file
while [[ $# -gt 0 ]]; do
    case $1 in
        -l|--lock-file)
            LOCKFILE="$2"
            shift 2
            ;;
        -h|--help)
            usage
            ;;
        *)
            echo "Unknown option: $1"
            usage
            ;;
    esac
done

# Validate required input
if [[ -z "$LOCKFILE" ]]; then
    echo "Error: --lock-file is required."
    usage
fi

if [[ ! -f "$LOCKFILE" ]]; then
    echo "Error: Lock file not found at '$LOCKFILE'"
    exit 1
fi

# --- Execution ---

mkdir -p "$DEST_DIR"

echo "Starting download of RPMs from $LOCKFILE..."

# Check if yq is installed
if command -v yq &> /dev/null; then
    urls=$(yq '.arches[].packages[].url' "$LOCKFILE")
else
    echo "Warning: 'yq' not found. Falling back to grep/sed (less robust)..."
    urls=$(grep -oP '(?<=url: ).*' "$LOCKFILE")
fi

total=$(echo "$urls" | grep -c '^')
count=0

for url in $urls; do
    count=$((count + 1))
    filename=$(basename "$url")
    
    echo "[$count/$total] Downloading: $filename"
    
    # Download file
    wget -q -nc -P "$DEST_DIR" "$url"
    
    if [ $? -eq 0 ]; then
        # Verify checksum if yq is available
        if command -v yq &> /dev/null; then
            checksum=$(yq ".arches[].packages[] | select(.url == \"$url\") | .checksum" "$LOCKFILE" 2>/dev/null | head -n 1)
            
            if [ -n "$checksum" ]; then
                echo "$checksum  $DEST_DIR/$filename" | sha256sum -c - &>/dev/null
                if [ $? -eq 0 ]; then
                    echo "✓ Checksum verified for $filename"
                else
                    echo "✗ Checksum mismatch for $filename"
                    exit 1
                fi
            fi
        fi
    else
        echo "Error: Failed to download $url"
    fi
done

echo "Finished! RPMs are located in $DEST_DIR"