dir=./cachi2/output/deps/npm-vath
mkdir -p $dir

for i in "${!sources[@]}"; do
    index=$((i + 1))
    echo "${i}: Fetching npm dependencies for ${sources[$i]}"
    hermeto fetch-deps npm \
        --source "${sources[$i]}" \
        --output "./cachi2/tmp/npm-$index" \
        --dev-package-managers
    #cp -r "./cachi2/tmp/npm-$index"/deps/npm/* $dir
    rsync -a "./cachi2/tmp/npm-$index/deps/npm/" "$dir/"
done

echo "Successfully fetched npm packages into $dir"