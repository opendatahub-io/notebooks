#!/usr/bin/env bash
set -euo pipefail

hermeto() {
  podman run --rm -ti \
    -v "$PWD:$PWD:z" \
    -w "$PWD" \
    ghcr.io/hermetoproject/hermeto:latest \
    "$@"
}

