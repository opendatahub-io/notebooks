ARG FEDORA_TAG=43
FROM registry.fedoraproject.org/fedora:${FEDORA_TAG}

RUN dnf install -y \
    python3 python3-pip \
    golang \
    make \
    podman \
    yamllint \
    git \
    && dnf clean all

# Install uv — the ./uv wrapper script needs uv on PATH to bootstrap
COPY --from=ghcr.io/astral-sh/uv:latest /uv /usr/local/bin/uv
