#!/usr/bin/env -S bash --norc --noprofile
# ./uv — run the project-pinned version of uv.
#
# Delegates via `uv tool run` when the system uv differs from the pinned
# version. This avoids version mismatch errors when your system uv (e.g.
# Homebrew) differs from the version used for lock generation.
#
# Usage:
#   ./uv sync
#   ./uv run pytest
#   ./uv pip compile ...
#
# The pinned version is cached by uvx after the first run.
set -Eeuo pipefail

UV_VERSION="0.11.27"

# Fast path: use the system uv directly if it already matches the pinned version
if current=$(uv --version 2>/dev/null); then
    if [[ "$current" == "uv ${UV_VERSION}" || "$current" == "uv ${UV_VERSION} "* ]]; then
        exec uv "$@"
    fi
fi

# Slow path: run the pinned version via uv tool run (downloaded and cached on first use)
exec uv tool run "uv@${UV_VERSION}" "$@"
