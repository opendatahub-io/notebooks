bin/
ci/
tests/

# IDE
.idea/

# git
# .git/ is intentionally NOT ignored: the Dockerfile needs it to resolve the
# code-server git submodule (COPY .git ...). Ensure CI uses a shallow clone.
.gitignore
.gitkeep

# Python cache
**/.mypy_cache/
**/.pytest_cache/
**/__pycache__/
**/*.pyc

# Virtual environment
env/
venv/
.venv/
*.egg-info/

# Dockerfiles
**/Dockerfile*

# Logs
*.log

# OS-specific files
**/.DS_Store
Thumbs.db

# Node
**/node_modules/

# Documentation
*.md
docs/
examples/
