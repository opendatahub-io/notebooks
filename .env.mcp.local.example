# Jira MCP Credentials
# Copy this file to .env.mcp.local and fill in your values
# DO NOT commit .env.mcp.local - it contains secrets

# Your Atlassian email (the one you use to log into Jira)
JIRA_EMAIL=your.email@redhat.com

# Jira API Token - generate at:
# https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_API_TOKEN=your-api-token-here

# Jira instance URL (usually doesn't need to change)
JIRA_URL=https://redhat.atlassian.net
