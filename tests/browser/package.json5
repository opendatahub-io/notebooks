{
  "type": "module",
  "private": "true",
  "name": "notebooks",
  "version": "1.0.0",
  "description": "Tests for Open Data Hub / OpenShift AI Notebook / Workbench images in TypeScript.",
  "main": "index.js",
  "scripts": {
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    // NOTE: This is the single source of truth for Playwright version.
    // The container image tag (v{version}-noble) is derived from @playwright/test version
    // by .github/actions/playwright-test/action.yml
    "playwright": "=1.60.0",
    "@playwright/test": "=1.60.0",

    "testcontainers": "^11.14.0",

    "tslog": "^4",
    "typescript": "^6.0.3",
    "@types/node": "^25.7.0",
    "@kubernetes/client-node": "^1.4.0",

    // ESLint with type-aware rules + Playwright plugin (see ADR 0012)
    "eslint": "^10.3.0",
    "@eslint/js": "^10.0.1",
    "typescript-eslint": "^8.59.3",
    "eslint-plugin-playwright": "^2.10.2",
    "jiti": "^2.7.0"
  },
  "packageManager": "pnpm@10.33.4",
  "pnpm": {
    // Refuse packages published less than 3 days ago (Shai-Hulud supply-chain worm mitigation)
    "minimumReleaseAge": "3d",
    "overrides": {
      // CVE-2026-41242: arbitrary code execution via injected protobuf definition type fields
      "protobufjs": ">=7.5.5 <8"
    }
  }
}
