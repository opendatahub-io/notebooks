{
  "compilerOptions": {
    "target": "ESNext",
    "module": "EsNext",
    "moduleResolution": "NodeNext",

    "allowJs": true,
    "esModuleInterop": true,
    "allowImportingTsExtensions": true,
    "allowSyntheticDefaultImports": true,
    "noEmit": true,

    "strict": true,
    "noImplicitAny": true,
    "noImplicitReturns": true,
    "noImplicitThis": true,
    "noUnusedLocals": true,
    "allowUnreachableCode": false
  }
}
