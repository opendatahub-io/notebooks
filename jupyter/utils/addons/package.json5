// https://pnpm.io/package_json
{
  type: 'module',
  private: true,
  name: 'jupyter-utils-addons',
  version: '1.0.0',
  description: 'Addons for JupyterLab workbenches',
  license: 'Apache-2.0',
  scripts: {
    test: './test-build.sh',
    build: 'webpack --mode production',
    'build:dev': 'webpack --mode development',
    watch: 'webpack --watch',
    clean: 'rm -rf dist .cache',
    'build:clean': 'pnpm clean && pnpm build',
  },
  dependencies: {
    '@patternfly/patternfly': '6.6.0',
  },
  devDependencies: {
    // webpack to minify css file
    '@types/node': '^26.1.0',
    '@types/webpack': '^5.28.5',
    // plugins for webpack
    'css-loader': '^7.1.4',
    'html-loader': '^5.1.0',
    'html-webpack-plugin': '^5.6.7',
    'mini-css-extract-plugin': '^2.10.2',
    'purgecss-webpack-plugin': '^8.0.0',
    typescript: '^6.0.3',
    webpack: '^5.108.4',
    'webpack-cli': '^7.2.1',
  },
  // DO NOT add "pnpm": { ... } here — pnpm 11 ignores it silently (pnpm#11536).
  // All pnpm settings go in pnpm-workspace.yaml.
  // "packageManager": "pnpm@10.8.1" // forces install of a precise version, so annoying
}
