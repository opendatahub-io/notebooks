// https://pnpm.io/package_json
{
  type: 'module',
  private: true,
  name: 'jupyter-utils-addons',
  version: '1.0.0',
  description: 'Addons for JupyterLab workbenches',
  license: 'Apache-2.0',
  scripts: {
    test: './test-build.sh',
    build: 'webpack --mode production',
    'build:dev': 'webpack --mode development',
    start: 'webpack serve --open',
    watch: 'webpack --watch',
    clean: 'rm -rf dist .cache',
    'build:clean': 'pnpm clean && pnpm build',
  },
  dependencies: {
    '@patternfly/patternfly': '6.4.0',
  },
  devDependencies: {
    // webpack to minify css file
    '@types/node': '^25.7.0',
    '@types/webpack': '^5.28.5',
    // plugins for webpack
    'css-loader': '^7.1.4',
    'html-loader': '^5.1.0',
    'html-webpack-plugin': '^5.6.7',
    'mini-css-extract-plugin': '^2.10.2',
    'purgecss-webpack-plugin': '^8.0.0',
    typescript: '^6.0.3',
    webpack: '^5.106.2',
    'webpack-cli': '^7.0.2',
    'webpack-dev-server': '^5.2.4',
  },
  pnpm: {
    // Refuse packages published less than 3 days ago (Shai-Hulud supply-chain worm mitigation)
    minimumReleaseAge: '3d',
  },
  // "packageManager": "pnpm@10.8.1" // forces install of a precise version, so annoying
}
